# Ceremony binary artifacts — large, regenerated by scripts/ceremony.sh.
# The TRANSCRIPT.md and vk-hashes.json text outputs ARE tracked.
ceremony/pot/
ceremony/phase2/
ceremony/transcript/
ceremony/*.ptau
ceremony/*.zkey

# Build outputs — regenerated by scripts/build.sh.
build/*/*.r1cs
build/*/*.sym
build/*/*.wasm
build/*/*_js/
build/*/*.zkey

# Ceremony private signing keys must NEVER be committed.
ceremony/keys/*_ed25519
ceremony/keys/*_ed25519.priv
ceremony/keys/id_*
