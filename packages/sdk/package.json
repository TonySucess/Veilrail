  "devDependencies": {
    "@solana/web3.js": "1.95.4",
    "@types/node": "catalog:",
    "snarkjs": "^0.7.5",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "poseidon-lite": "^0.3.0"
  }
